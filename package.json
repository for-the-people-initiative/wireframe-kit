{
  "name": "@for-the-people-initiative/wireframe-kit",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "description": "Hand-drawn wireframe component library — Vue 3 components with a sketchy aesthetic for low-fidelity mockups",
  "author": "For The People",
  "license": "MIT",
  "keywords": [
    "wireframe",
    "low-fidelity",
    "mockup",
    "prototype",
    "vue",
    "vue3",
    "components",
    "design-system"
  ],
  "files": [
    "dist",
    "src/scss",
    "tokens"
  ],
  "exports": {
    ".": {
      "types": "./dist/ts/tokens.ts",
      "import": "./dist/ts/tokens.ts"
    },
    "./css": "./dist/css/tokens.css",
    "./css/tokens.css": "./dist/css/tokens.css",
    "./scss": "./dist/scss/_tokens.scss",
    "./scss/wireframe": "./src/scss/wireframe.scss",
    "./scss/fonts": "./src/scss/fonts.scss",
    "./scss/tokens": "./dist/scss/_tokens.scss",
    "./scss/mixins/*": "./src/scss/mixins/*",
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.d.ts"
    },
    "./components/*": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/components/*/index.js",
      "style": "./dist/components/*/style.css"
    },
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "types": [
        "./dist/types/index.d.ts"
      ],
      "components/*": [
        "./dist/types/index.d.ts"
      ],
      "composables": [
        "./dist/composables/index.d.ts"
      ]
    }
  },
  "main": "./dist/ts/tokens.ts",
  "scripts": {
    "build:tokens": "tsx scripts/build-tokens.ts",
    "build:components": "vite build",
    "build:types": "tsc -p tsconfig.build.json && tsc -p tsconfig.composables.json",
    "build:lib": "npm run build:tokens && npm run build:components && npm run build:types",
    "dev": "npm run build:tokens && npm --prefix server run dev",
    "build": "npm run build:tokens && npm --prefix server install && npm --prefix server run build",
    "preview": "npm --prefix server run preview",
    "prepublishOnly": "npm run build:lib",
    "publish-all": "npm run build:tokens && npm publish && node ./workflow/DeploymentCDN/preprocessUtilityClasses.cjs && node ./workflow/DeploymentCDN/deployUtilityClassesToCDN.cjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "story:dev": "histoire dev",
    "story:build": "histoire build",
    "story:preview": "histoire preview",
    "process-utility-classes": "node ./workflow/DeploymentCDN/preprocessUtilityClasses.cjs",
    "deploy-utility-classes": "node ./workflow/DeploymentCDN/deployUtilityClassesToCDN.cjs"
  },
  "devDependencies": {
    "@azure/storage-blob": "^12.16.0",
    "@histoire/plugin-vue": "~0.17.17",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/manager-api": "^8.6.14",
    "@storybook/theming": "^8.6.14",
    "@storybook/vue3": "^8.6.15",
    "@storybook/vue3-vite": "^8.6.15",
    "@vitejs/plugin-vue": "^4.2.3",
    "basic-ftp": "^5.0.3",
    "consola": "^3.2.3",
    "dotenv": "^16.4.5",
    "glob-promise": "^6.0.7",
    "histoire": "~0.17.17",
    "lodash": "^4.17.21",
    "sass": "^1.64.2",
    "storybook": "^8.6.15",
    "storybook-design-token": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "uglifycss": "^0.0.29",
    "vite": "^4.4.5",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vue": "^3.5.0",
    "vue-tsc": "^3.2.4"
  },
  "dependencies": {}
}
